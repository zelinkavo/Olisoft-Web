---
/**
 * AppLandingLayout.astro
 *
 * Shared layout for app sub-landing pages.
 * Provides: ambient background, hero header with parallax,
 * breadcrumb nav, content container, footer nav.
 */
import BaseLayout from './BaseLayout.astro';
import Badge from '../components/ui/Badge.astro';

interface Props {
  title: string;
  description: string;
  color: 'gold' | 'steel' | 'teal';
  technologies?: string[];
}

const { title, description, color, technologies = [] } = Astro.props;

const orbClass = `section__orb--${color}`;
const moteClass = `mote--${color}`;
const cometClass = `comet--${color}`;
---

<BaseLayout title={title} description={description}>

  <article class="app-landing section--themed" id="app-top">
    <div class="section__bg section__bg--app" aria-hidden="true">
      <div class="section__grid section__grid--sparse"></div>

      <div class={`section__orb ${orbClass}`}></div>

      <div class={`mote ${moteClass}`} style="top:5%;left:12%;--mote-dur:18s;--mote-dx:20px;--mote-dy:-15px"></div>
      <div class={`mote ${moteClass}`} style="top:15%;right:18%;--mote-dur:22s;--mote-dx:-12px;--mote-dy:18px;animation-delay:-5s"></div>
      <div class={`mote ${moteClass} mote--lg`} style="top:8%;right:35%;--mote-dur:24s;--mote-dx:-8px;--mote-dy:12px;animation-delay:-12s"></div>
      <div class={`mote ${moteClass}`} style="top:20%;left:28%;--mote-dur:16s;--mote-dx:15px;--mote-dy:-10px;animation-delay:-3s"></div>

      <div class={`comet ${cometClass}`} style="top:8%;left:5%;--comet-dur:14s;--comet-tx:300px;--comet-ty:-25px;--comet-angle:-6deg"></div>
      <div class={`comet ${cometClass} comet--reverse`} style="top:18%;right:5%;--comet-dur:16s;--comet-tx:-250px;--comet-ty:-15px;--comet-angle:4deg;animation-delay:-5s"></div>
    </div>

    <div class="content-wrapper">
      <!-- Breadcrumb -->
      <nav class="app-landing__nav" aria-label="Breadcrumb">
        <div class="container">
          <a href="/" class="back-link">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            OliSoft APPs
          </a>
        </div>
      </nav>

      <!-- Hero -->
      <header class="app-landing__header" id="app-parallax">
        <div class="project__layer project__layer--orbs" data-depth="0.04" aria-hidden="true">
          <div class={`project-orb project-orb--${color}`}></div>
        </div>

        <div class="project__layer project__layer--content" data-depth="0.07">
          <div class="container container--narrow text-center project__content-inner">
            <div class="app-landing__meta" data-animate="fade-up">
              {technologies.map((tech) => (
                <Badge variant={color === 'gold' ? 'ai' : color === 'steel' ? 'dev' : 'infra'}>
                  {tech}
                </Badge>
              ))}
            </div>
            <h1 class="app-landing__title" data-animate="fade-up" style="--stagger-index: 1">{title}</h1>
            <p class="app-landing__subtitle" data-animate="fade-up" style="--stagger-index: 2">{description}</p>

            <div class="app-landing__cta" data-animate="fade-up" style="--stagger-index: 3">
              <a href="#" class="btn btn--primary" aria-label="Descargar en Google Play">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
                  <path d="M3,20.5V3.5C3,2.91 3.34,2.39 3.84,2.15L13.69,12L3.84,21.85C3.34,21.61 3,21.09 3,20.5M16.81,15.12L6.05,21.34L14.54,12.85L16.81,15.12M20.16,10.81C20.5,11.08 20.75,11.5 20.75,12C20.75,12.5 20.53,12.9 20.18,13.18L17.89,14.5L15.39,12L17.89,9.5L20.16,10.81M6.05,2.66L16.81,8.88L14.54,11.15L6.05,2.66Z"/>
                </svg>
                Descargar en Google Play
              </a>
            </div>
          </div>
        </div>
      </header>

      <!-- Content -->
      <main class="app-landing__content container container--narrow">
        <slot />
      </main>

      <!-- Footer nav -->
      <footer class="app-landing__footer container">
        <div class="footer-nav">
          <a href="/" class="btn btn--secondary">
            ← Volver a OliSoft APPs
          </a>
        </div>
      </footer>
    </div>
  </article>

</BaseLayout>

<style>
  .container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-xl);
  }

  .container--narrow {
    max-width: 800px;
  }

  .app-landing {
    position: relative;
    padding-top: calc(var(--nav-height) + var(--space-xl));
    padding-bottom: var(--space-4xl);
    overflow-x: hidden;
  }

  .content-wrapper {
    position: relative;
    z-index: 1;
  }

  .section__bg--app {
    height: 100%;
    z-index: 0;
  }

  /* Nav */
  .app-landing__nav {
    margin-bottom: var(--space-2xl);
    position: relative;
    z-index: 5;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
    transition: color var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-accent-primary);
  }

  /* Header / Parallax */
  .app-landing__header {
    position: relative;
    padding: var(--space-xl) 0 var(--space-4xl);
    margin-bottom: var(--space-4xl);
  }

  .project__layer {
    will-change: transform;
  }

  .project__layer--orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .project__layer--content {
    position: relative;
    z-index: 2;
  }

  .project__content-inner {
    animation: contentFloat 8s ease-in-out infinite;
  }

  @keyframes contentFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .project-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }

  .project-orb--gold {
    width: 600px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(212, 162, 78, 0.08);
    animation: orbFloatPulse 12s ease-in-out infinite;
  }

  .project-orb--steel {
    width: 500px;
    height: 350px;
    top: 50%;
    left: 45%;
    transform: translate(-50%, -50%);
    background: rgba(124, 149, 196, 0.07);
    animation: orbDriftPulse 14s ease-in-out infinite 2s;
  }

  .project-orb--teal {
    width: 500px;
    height: 350px;
    top: 50%;
    left: 55%;
    transform: translate(-50%, -50%);
    background: rgba(91, 184, 166, 0.07);
    animation: orbDriftPulse 16s ease-in-out infinite 5s;
  }

  @keyframes orbFloatPulse {
    0%   { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    50%  { transform: translate(-50%, -52%) scale(1.05); opacity: 0.8; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  }

  @keyframes orbDriftPulse {
    0%   { transform: translate(-50%, -50%); opacity: 1; }
    50%  { transform: translate(-48%, -48%); opacity: 0.85; }
    100% { transform: translate(-50%, -50%); opacity: 1; }
  }

  /* Meta / Title */
  .app-landing__meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
  }

  .app-landing__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--space-md);
    color: var(--color-text-primary);
  }

  .app-landing__subtitle {
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }

  .app-landing__cta {
    margin-top: var(--space-2xl);
  }

  /* Content */
  .app-landing__content {
    display: flex;
    flex-direction: column;
  }

  /* Footer */
  .app-landing__footer {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-nav {
    display: flex;
    justify-content: flex-start;
  }

  .text-center {
    text-align: center;
  }

  /* Button */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.9rem;
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-md);
    border: none;
    cursor: pointer;
    text-decoration: none;
    line-height: 1;
    transition:
      transform var(--transition-fast),
      box-shadow var(--transition-fast),
      background var(--transition-fast),
      border-color var(--transition-fast);
  }

  .btn--primary {
    background: var(--gradient-accent);
    color: var(--color-bg-primary);
  }

  .btn--primary:hover {
    box-shadow: 0 4px 20px rgba(212, 162, 78, 0.3);
    color: var(--color-bg-primary);
    transform: translateY(-1px);
  }

  .btn--secondary {
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }

  .btn--secondary:hover {
    color: var(--color-accent-primary);
    border-color: var(--color-border-accent);
    transform: translateY(-1px);
  }

  /* Background ambient */
  .section__bg {
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 100%;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .section__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 15%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 15%, transparent 70%);
  }

  .section__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .section__orb--gold { width: 500px; height: 400px; top: -5%; right: 5%; background: rgba(212, 162, 78, 0.06); animation: orbFloat 16s ease-in-out infinite; }
  .section__orb--steel { width: 450px; height: 450px; top: 10%; left: -5%; background: rgba(124, 149, 196, 0.05); animation: orbFloat 18s ease-in-out infinite 3s; }
  .section__orb--teal { width: 500px; height: 400px; top: 30%; right: 0%; background: rgba(91, 184, 166, 0.05); animation: orbFloat 20s ease-in-out infinite 5s; }

  @keyframes orbFloat {
    0%   { transform: translate(0, 0); opacity: 1; }
    33%  { transform: translate(15px, -20px); opacity: 0.65; }
    66%  { transform: translate(-12px, -8px); opacity: 0.8; }
    100% { transform: translate(0, 0); opacity: 1; }
  }

  .mote {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    animation: moteDrift var(--mote-dur, 20s) ease-in-out infinite;
    pointer-events: none;
  }

  .mote--lg { width: 5px; height: 5px; }
  .mote--gold { background: rgba(212, 162, 78, 0.5); box-shadow: 0 0 12px rgba(212, 162, 78, 0.25); }
  .mote--steel { background: rgba(124, 149, 196, 0.5); box-shadow: 0 0 12px rgba(124, 149, 196, 0.25); }
  .mote--teal { background: rgba(91, 184, 166, 0.5); box-shadow: 0 0 12px rgba(91, 184, 166, 0.25); }

  @keyframes moteDrift {
    0%   { transform: translate(0, 0); opacity: 0.5; }
    25%  { transform: translate(var(--mote-dx, 10px), var(--mote-dy, -10px)); opacity: 1; }
    50%  { transform: translate(calc(var(--mote-dx, 10px) * -0.5), calc(var(--mote-dy, -10px) * 0.7)); opacity: 0.6; }
    75%  { transform: translate(calc(var(--mote-dx, 10px) * 0.3), calc(var(--mote-dy, -10px) * -0.4)); opacity: 1; }
    100% { transform: translate(0, 0); opacity: 0.5; }
  }

  .comet {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    pointer-events: none;
    animation: cometCross var(--comet-dur, 18s) linear infinite;
    opacity: 0;
  }

  .comet::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 100%;
    width: 35px;
    height: 2px;
    transform: translateY(-50%) rotate(var(--comet-angle, 0deg));
    transform-origin: right center;
    border-radius: 2px;
  }

  .comet--reverse::after {
    right: auto;
    left: 100%;
    transform-origin: left center;
  }

  .comet--gold { background: rgba(212, 162, 78, 0.6); box-shadow: 0 0 8px rgba(212, 162, 78, 0.3); }
  .comet--gold::after { background: linear-gradient(90deg, transparent, rgba(212, 162, 78, 0.35)); }
  .comet--steel { background: rgba(124, 149, 196, 0.6); box-shadow: 0 0 8px rgba(124, 149, 196, 0.3); }
  .comet--steel::after { background: linear-gradient(90deg, transparent, rgba(124, 149, 196, 0.35)); }
  .comet--teal { background: rgba(91, 184, 166, 0.6); box-shadow: 0 0 8px rgba(91, 184, 166, 0.3); }
  .comet--teal::after { background: linear-gradient(90deg, transparent, rgba(91, 184, 166, 0.35)); }

  .comet--reverse.comet--gold::after { background: linear-gradient(90deg, rgba(212, 162, 78, 0.35), transparent); }
  .comet--reverse.comet--steel::after { background: linear-gradient(90deg, rgba(124, 149, 196, 0.35), transparent); }
  .comet--reverse.comet--teal::after { background: linear-gradient(90deg, rgba(91, 184, 166, 0.35), transparent); }

  @keyframes cometCross {
    0%   { transform: translate(0, 0); opacity: 0; }
    5%   { opacity: 0.7; }
    45%  { opacity: 0.5; }
    50%  { transform: translate(var(--comet-tx, 200px), var(--comet-ty, -30px)); opacity: 0.7; }
    95%  { opacity: 0.5; }
    98%  { opacity: 0; }
    100% { transform: translate(calc(var(--comet-tx, 200px) * 2), calc(var(--comet-ty, -30px) * 2)); opacity: 0; }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 var(--space-md);
    }
  }

  @media (max-width: 640px) {
    .section__orb,
    .comet {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section__orb,
    .mote,
    .comet,
    .project__content-inner {
      animation: none !important;
    }
  }
</style>

<script>
  function initAppParallax() {
    const hero = document.getElementById('app-parallax');
    if (!hero) return;
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced && window.innerWidth >= 768) {
      const layers = hero.querySelectorAll<HTMLElement>('[data-depth]');
      let targetX = 0, targetY = 0, currentX = 0, currentY = 0;

      hero.addEventListener('mousemove', (e) => {
        const rect = hero.getBoundingClientRect();
        targetX = (e.clientX - rect.left - rect.width / 2) / rect.width;
        targetY = (e.clientY - rect.top - rect.height / 2) / rect.height;
      });

      hero.addEventListener('mouseleave', () => {
        targetX = 0;
        targetY = 0;
      });

      function animateParallax() {
        currentX += (targetX - currentX) * 0.06;
        currentY += (targetY - currentY) * 0.06;
        layers.forEach((layer) => {
          const depth = parseFloat(layer.dataset.depth || '0');
          layer.style.transform = `translate(${currentX * depth * 80}px, ${currentY * depth * 50}px)`;
        });
        requestAnimationFrame(animateParallax);
      }
      animateParallax();
    }
  }

  document.addEventListener('astro:page-load', initAppParallax);
  initAppParallax();
</script>
